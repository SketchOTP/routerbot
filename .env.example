# RouterBot environment variables (all optional)
#
# Copy to your shell profile or /etc/routerbot/environment for systemd installs.

# Bind address (default: 127.0.0.1 from config)
# ROUTERBOT_HOST=127.0.0.1

# Listen port (default: 4117)
# ROUTERBOT_PORT=4117

# API key for /v1 and /api (overrides data/config.json)
# ROUTERBOT_API_KEY=your-secret-key

# Tailscale setup script overrides
# ROUTERBOT_TAILSCALE_SERVE_PORT=9420
# ROUTERBOT_TAILSCALE_FUNNEL_PORT=10000
# ROUTERBOT_TAILSCALE_HOST=your-machine.tailXXXX.ts.net

# systemd install overrides
# ROUTERBOT_USER=your-user
# ROUTERBOT_GROUP=your-group
# ROUTERBOT_NODE=/usr/bin/node
